PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/mockmate

# JWT
JWT_SECRET=
JWT_EXPIRE=7d

# LiveKit Cloud
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# AI Providers (Groq primary, Cerebras fallback, Mistral final fallback)
GROQ_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=

# Speech
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
CARTESIA_MODEL=sonic-2
CARTESIA_VOICE_ID=d46abd1d-2d02-43e8-819f-51fb652c1c61
CARTESIA_LANGUAGE=en

# Storage (local for now, abstracted for future S3/Cloudinary switch)
STORAGE_DRIVER=local
STORAGE_BASE_PATH=./storage

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
FROM_NAME=MockMate

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend
CLIENT_URL=http://localhost:3000
