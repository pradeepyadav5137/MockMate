# ─── Core ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# ─── Authentication ─────────────────────────────────────────────────────
# SECURITY: Must be at least 32 characters in production. Never use a default.
JWT_SECRET=your-jwt-secret-here-change-me
JWT_EXPIRE=7d

# Separate secret for internal agent↔backend communication.
# MUST differ from JWT_SECRET.
AGENT_INTERNAL_SECRET=your-agent-internal-secret-here-change-me

# ─── AWS / DynamoDB ──────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
DYNAMODB_TABLE_NAME=MockMate_Users
DYNAMODB_INTERVIEW_TABLE=MockMate_Interviews
DYNAMODB_PAYMENT_TABLE=MockMate_Payments
DYNAMODB_TICKET_TABLE=MockMate_Tickets
DYNAMODB_FEEDBACK_TABLE=MockMate_UserFeedback

# ─── Razorpay ────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# Required in production. Configure in Razorpay Dashboard → Settings → Webhooks.
# RAZORPAY_WEBHOOK_SECRET=your-webhook-secret-from-dashboard

# ─── Brevo (Email) ──────────────────────────────────────────────────────
# Required in production. Get API key from https://app.brevo.com
# BREVO_API_KEY=your-brevo-api-key
# BREVO_SENDER_EMAIL=noreply@mockmate.in
# BREVO_SENDER_NAME=MockMate

# ─── LiveKit ─────────────────────────────────────────────────────────────
LIVEKIT_URL=wss://your-livekit-url
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_AGENT_NAME=alex-interviewer

# ─── AI Providers ───────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
CEREBRAS_API_KEY=your-cerebras-api-key
MISTRAL_API_KEY=your-mistral-api-key
DEEPGRAM_API_KEY=your-deepgram-api-key
DEEPGRAM_MODEL=nova-2

# ─── TTS ─────────────────────────────────────────────────────────────────
CARTESIA_API_KEY=your-cartesia-api-key
CARTESIA_MODEL=sonic-2
CARTESIA_VOICE_ID=d46abd1d-2d02-43e8-819f-51fb652c1c61
CARTESIA_LANGUAGE=en

# ─── Storage ─────────────────────────────────────────────────────────────
# local = development only. s3 = production.
STORAGE_DRIVER=local
STORAGE_BASE_PATH=./storage
# Required when STORAGE_DRIVER=s3
# S3_BUCKET_NAME=mockmate-recordings
# S3_REGION=ap-south-1

# ─── Internal API URL (for agent→backend communication) ─────────────────
# INTERNAL_API_URL=http://localhost:5000/api

# ─── Google OAuth (optional) ────────────────────────────────────────────
# Ensure you add http://localhost:5000/api/auth/google/callback to your Authorized Redirect URIs in the Google Cloud Console.
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
